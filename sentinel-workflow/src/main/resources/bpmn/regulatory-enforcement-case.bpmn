<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:camunda="http://camunda.org/schema/1.0/bpmn" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_1" targetNamespace="https://sentinel.local/workflow" exporter="Camunda Modeler" exporterVersion="5.39.0">
  <bpmn:process id="regulatoryEnforcementCase" name="Regulatory Enforcement Case" isExecutable="true" camunda:historyTimeToLive="30">
    <bpmn:startEvent id="startEvent" name="Case Created">
      <bpmn:outgoing>Flow_1</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:userTask id="triageTask" name="Triage Case" camunda:candidateGroups="TRIAGE_OFFICER,SUPERVISOR">
      <bpmn:incoming>Flow_1</bpmn:incoming>
      <bpmn:outgoing>Flow_2</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="investigationTask" name="Investigate Case" camunda:candidateGroups="INVESTIGATOR,SUPERVISOR">
      <bpmn:incoming>Flow_2</bpmn:incoming>
      <bpmn:outgoing>Flow_3</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:boundaryEvent id="investigationEscalationTimer" name="Investigation Escalation" cancelActivity="false" attachedToRef="investigationTask">
      <bpmn:outgoing>Flow_6</bpmn:outgoing>
      <bpmn:timerEventDefinition>
        <bpmn:timeDuration>${investigationEscalationDuration}</bpmn:timeDuration>
      </bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>
    <bpmn:serviceTask id="recordInvestigationEscalation" name="Record Investigation Escalation" camunda:delegateExpression="${investigationEscalationDelegate}">
      <bpmn:incoming>Flow_6</bpmn:incoming>
      <bpmn:outgoing>Flow_7</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:endEvent id="escalationRecorded" name="Escalation Recorded">
      <bpmn:incoming>Flow_7</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:userTask id="reviewTask" name="Review Recommendation" camunda:candidateGroups="CASE_REVIEWER,SUPERVISOR">
      <bpmn:incoming>Flow_3</bpmn:incoming>
      <bpmn:outgoing>Flow_4</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="decisionTask" name="Approve Decision" camunda:candidateGroups="DECISION_MAKER,SUPERVISOR">
      <bpmn:incoming>Flow_4</bpmn:incoming>
      <bpmn:outgoing>Flow_5</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:endEvent id="decisionCompleted" name="Decision Completed">
      <bpmn:incoming>Flow_5</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_1" sourceRef="startEvent" targetRef="triageTask" />
    <bpmn:sequenceFlow id="Flow_2" sourceRef="triageTask" targetRef="investigationTask" />
    <bpmn:sequenceFlow id="Flow_3" sourceRef="investigationTask" targetRef="reviewTask" />
    <bpmn:sequenceFlow id="Flow_4" sourceRef="reviewTask" targetRef="decisionTask" />
    <bpmn:sequenceFlow id="Flow_5" sourceRef="decisionTask" targetRef="decisionCompleted" />
    <bpmn:sequenceFlow id="Flow_6" sourceRef="investigationEscalationTimer" targetRef="recordInvestigationEscalation" />
    <bpmn:sequenceFlow id="Flow_7" sourceRef="recordInvestigationEscalation" targetRef="escalationRecorded" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="regulatoryEnforcementCase">
      <bpmndi:BPMNShape id="StartEventShape" bpmnElement="startEvent">
        <dc:Bounds x="152" y="132" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="TriageTaskShape" bpmnElement="triageTask">
        <dc:Bounds x="240" y="110" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="InvestigationTaskShape" bpmnElement="investigationTask">
        <dc:Bounds x="400" y="110" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EscalationServiceTaskShape" bpmnElement="recordInvestigationEscalation">
        <dc:Bounds x="560" y="170" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EscalationEndShape" bpmnElement="escalationRecorded">
        <dc:Bounds x="712" y="192" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="ReviewTaskShape" bpmnElement="reviewTask">
        <dc:Bounds x="560" y="110" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="DecisionTaskShape" bpmnElement="decisionTask">
        <dc:Bounds x="720" y="110" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="DecisionEndShape" bpmnElement="decisionCompleted">
        <dc:Bounds x="872" y="132" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="TimerShape" bpmnElement="investigationEscalationTimer">
        <dc:Bounds x="432" y="192" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Flow_1_di" bpmnElement="Flow_1">
        <di:waypoint x="188" y="150" />
        <di:waypoint x="240" y="150" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_2_di" bpmnElement="Flow_2">
        <di:waypoint x="340" y="150" />
        <di:waypoint x="400" y="150" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_3_di" bpmnElement="Flow_3">
        <di:waypoint x="500" y="150" />
        <di:waypoint x="560" y="150" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_4_di" bpmnElement="Flow_4">
        <di:waypoint x="660" y="150" />
        <di:waypoint x="720" y="150" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_5_di" bpmnElement="Flow_5">
        <di:waypoint x="820" y="150" />
        <di:waypoint x="872" y="150" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_6_di" bpmnElement="Flow_6">
        <di:waypoint x="468" y="210" />
        <di:waypoint x="560" y="210" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_7_di" bpmnElement="Flow_7">
        <di:waypoint x="660" y="210" />
        <di:waypoint x="712" y="210" />
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
