    <bpmn:messageFlow id="MessageFlow_ExternalEvidenceDelivered" name="External Evidence Delivered" sourceRef="Participant_ExternalEvidenceProvider" targetRef="awaitExternalEvidenceTask" />
    <bpmn:messageFlow id="MessageFlow_SendSanctionToRegistry" name="Send Sanction To Registry" sourceRef="sendSanctionToRegistryTask" targetRef="Participant_SanctionRegistry" />
    <bpmn:messageFlow id="MessageFlow_RegistryAcknowledged" name="Registry Acknowledged" sourceRef="Participant_SanctionRegistry" targetRef="awaitRegistryAcknowledgmentTask" />
    <bpmn:messageFlow id="MessageFlow_SendNotificationCommand" name="Send Notification Command" sourceRef="sendNotificationCommandTask" targetRef="Participant_NotificationService" />
    <bpmn:messageFlow id="MessageFlow_NotificationResultReceived" name="Notification Result Received" sourceRef="Participant_NotificationService" targetRef="awaitNotificationResultTask" />
    <bpmn:messageFlow id="MessageFlow_AppealFiled" name="Appeal Filed" sourceRef="Participant_Appellant" targetRef="appealFiledEvent" />
